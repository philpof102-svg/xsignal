{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.philpof102-svg/xsignal",
  "description": "x402 pay-per-call data tools for Base agents. Flagship get_intent ABSTAINS instead of guessing.",
  "status": "active",
  "repository": {
    "url": "https://github.com/philpof102-svg/xsignal",
    "source": "github"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@rakshasar/xsignal",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "@rakshasar/xsignal",
          "valueHint": "package-name"
        },
        {
          "type": "positional",
          "value": "xsignal-mcp",
          "valueHint": "bin-name"
        }
      ],
      "environmentVariables": [
        {
          "name": "XSIGNAL_WALLET",
          "description": "Your 0x Base address for 3 free calls per wallet; beyond that the tools return an x402 pay pointer.",
          "isRequired": false
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://xsignal-production.up.railway.app/mcp"
    }
  ]
}
